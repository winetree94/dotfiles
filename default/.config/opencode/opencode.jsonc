{
  "$schema": "https://opencode.ai/config.json",
  "theme": "ayu",
  "instructions": [
    "~/.config/opencode/AGENTS.md"
  ],

  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.3-codex-spark",

  "permission": {
    "bash": "allow",
    "edit": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "webfetch": "allow",
    "read": "allow",
    "write": "allow",
    "lsp": "allow"
  },
  "disabled_providers": [
    "openrouter",
    "synthetic",
    "minimax-cn",
    "minimax-cn-coding-plan",
    "minimax",
    "minimax-coding-plan",
    "github-models",
    "github-copilot-enterprise"
  ],
  "provider": {},
