{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.agents/AGENTS.md"
  ],
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-mini",
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "webfetch": "allow",
    "read": "allow",
    "write": "allow",
    "lsp": "allow"
  },
  "disabled_providers": [
    // "openrouter",
    "synthetic",
    "minimax-cn",
    "minimax-cn-coding-plan",
    "minimax",
    "minimax-coding-plan",
    "github-models",
    "github-copilot-enterprise"
  ],
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "litellm",
      "options": {
        "baseURL": "https://llm.winetree94.com/v1",
        "apiKey": "{env:LITELLM_API_KEY}"
      },
      "models": {
        "gemma-4-E4B-it-Q4_K_M": {
          "name": "gemma-4-E4B-it-Q4_K_M",
          "limit": {
            "context": 131072,
            "output": 131072
          }
        },
        "gemma-4-26B-A4B-it-UD-Q4_K_M": {
          "name": "gemma-4-26B-A4B-it-UD-Q4_K_M",
          "limit": {
            "context": 131072,
            "output": 131072
          }
        }
      }
    },
    "vllm-server": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Remote vLLM",
      "options": {
        "baseURL": "http://10.78.151.6:8002/v1",
        "apiKey": "EMPTY"
      },
      "models": {
        "Qwen3.5-397B-A17B-NVFP4": {
          "name": "Qwen3.5-397B-A17B-NVFP4",
          "id": "Qwen3.5-397B-A17B-NVFP4"
        }
      }
    }
  },
  "mcp": {
    // "web-reader": {
    //   "type": "remote",
    //   "url": "https://api.z.ai/api/mcp/web_reader/mcp",
    //   "headers": {
    //     "Authorization": "Bearer {env:ZAI_API_KEY}"
    //   }
    // },
    // "web-search-prime": {
    //   "type": "remote",
    //   "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
    //   "headers": {
    //     "Authorization": "Bearer {env:ZAI_API_KEY}"
    //   }
    // },
    // "brave-search": {
    //   "type": "local",
    //   "command": ["npx", "-y", "@brave/brave-search-mcp-server", "--transport", "http"],
    //   "env": {
    //     "BRAVE_API_KEY": "YOUR_API_KEY_HERE"
    //   }
    // },
    // "context7": {
    //   "type": "local",
    //   "command": [
    //     "npx",
    //     "-y",
    //     "@upstash/context7-mcp"
    //   ],
    //   "enabled": true
    // },
    // "playwright": {
    //   "type": "local",
    //   "command": [
    //     "npx",
    //     "@playwright/mcp@latest"
    //   ],
    //   "enabled": true
    // }
  },
  "plugin": [
    "opencode-gemini-auth@latest"
  ],
  "skills": {
    "paths": [
      "~/.agents/skills"
    ]
  }
}
